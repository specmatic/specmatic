<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="EXPECTED_FAILURES" class="ch.qos.logback.core.FileAppender">
        <file>${expectedFailuresJsonlFile:-build/conformance-expected-failures.jsonl}</file>
        <append>true</append>
        <encoder>
            <pattern>%msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="conformance_tests" level="debug"/>
    <logger name="com.networknt.schema.keyword.UnknownKeywordFactory" level="error"/>
    <logger name="conformance.expected-failures" level="info" additivity="false">
        <appender-ref ref="EXPECTED_FAILURES"/>
    </logger>

    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
