<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="TEST_RESULTS" class="ch.qos.logback.core.FileAppender">
        <file>${conformanceTestResultsJsonlFile:-build/conformance-test-results.jsonl}</file>
        <append>true</append>
        <encoder>
            <pattern>%msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="conformance_tests" level="debug"/>
    <logger name="com.networknt.schema.keyword.UnknownKeywordFactory" level="error"/>
    <logger name="conformance.test-results" level="info" additivity="false">
        <appender-ref ref="TEST_RESULTS"/>
    </logger>

    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
