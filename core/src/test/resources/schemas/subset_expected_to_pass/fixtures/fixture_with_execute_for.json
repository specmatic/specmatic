{
  "http-request": {
    "method": "POST",
    "path": "/orders"
  },
  "http-response": {
    "status": 201
  },
  "name": "example with executeFor fixtures",
  "before": [
    {
      "type": "http",
      "executeFor": {
        "scenarios": "all"
      },
      "http-request": {
        "baseUrl": "http://localhost:8080",
        "method": "GET",
        "path": "/setup/all"
      },
      "http-response": {
        "status": 200
      }
    },
    {
      "type": "http",
      "executeFor": {
        "scenarios": "negative"
      },
      "http-request": {
        "baseUrl": "http://localhost:8080",
        "method": "GET",
        "path": "/setup/negative"
      },
      "http-response": {
        "status": 200
      }
    }
  ]
}
