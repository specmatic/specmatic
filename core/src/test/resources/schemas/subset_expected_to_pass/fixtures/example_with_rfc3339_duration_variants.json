{
  "name": "example with RFC 3339 duration variants",
  "http-request": {
    "method": "POST",
    "path": "/orders"
  },
  "http-response": {
    "status": 201
  },
  "after": [
    {
      "type": "http",
      "wait": "P1W",
      "timeout": "P1Y2M3DT4H5M6S",
      "retry": {
        "max-attempts": 2,
        "delay": "PT30M"
      },
      "http-request": {
        "baseUrl": "http://localhost:9000",
        "method": "DELETE",
        "path": "/setup"
      },
      "http-response": {
        "status": 204
      }
    }
  ]
}
