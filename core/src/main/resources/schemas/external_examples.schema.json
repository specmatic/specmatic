{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/external-example-metadata-and-http.schema.json",
  "title": "External Examples Schema",
  "description": "A schema for external examples in Specmatic",
  "oneOf": [
    {
      "$ref": "#/$defs/Example"
    },
    {
      "$ref": "#/$defs/PartialExample"
    }
  ],
  "$defs": {
    "AnyValue": {},
    "Metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "transient": {
          "type": "boolean"
        },
        "delay-in-seconds": {
          "type": "integer",
          "minimum": 0
        },
        "delay-in-milliseconds": {
          "type": "integer",
          "minimum": 0
        },
        "http-stub-id": {
          "type": "string"
        }
      }
    },
    "Example": {
      "allOf": [
        {
          "$ref": "#/$defs/Metadata"
        },
        {
          "$ref": "#/$defs/RequestResponseSchema"
        },
        {
          "$ref": "#/$defs/FixtureHooks"
        }
      ]
    },
    "RequestResponseSchema": {
      "type": "object",
      "properties": {
        "http-request": {
          "$ref": "#/$defs/RequestSchema"
        },
        "http-response": {
          "$ref": "#/$defs/ResponseSchema"
        }
      },
      "required": ["http-request", "http-response"]
    },
    "PartialExample": {
      "allOf": [
        {
          "$ref": "#/$defs/Metadata"
        },
        {
          "type": "object",
          "properties": {
            "partial": {
              "$ref": "#/$defs/PartialRequestResponseSchema"
            }
          },
          "required": ["partial"]
        },
        {
          "$ref": "#/$defs/FixtureHooks"
        }
      ]
    },
    "FixtureHooks": {
      "type": "object",
      "properties": {
        "before": {
          "description": "Fixtures to execute before the example runs.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Fixture"
          }
        },
        "after": {
          "description": "Fixtures to execute after the example runs.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Fixture"
          }
        }
      }
    },
    "Fixture": {
      "oneOf": [
        {
          "$ref": "#/$defs/HttpFixture"
        }
      ]
    },
    "HttpFixture": {
      "type": "object",
      "examples": [
        {
          "type": "http",
          "executeFor": {
            "scenarios": "all"
          },
          "http-request": {
            "baseUrl": "http://localhost:9000",
            "method": "POST",
            "path": "/setup",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "state": "ready"
            }
          },
          "http-response": {
            "status": 200,
            "body": {
              "ok": true
            }
          }
        }
      ],
      "properties": {
        "type": {
          "const": "http",
          "description": "Fixture type discriminator. Currently only http is supported."
        },
        "wait": {
          "type": "string",
          "format": "duration"
        },
        "timeout": {
          "type": "string",
          "format": "duration"
        },
        "retry": {
          "description": "Retry policy to apply when the fixture call does not succeed immediately.",
          "$ref": "#/$defs/Retry"
        },
        "executeFor": {
          "description": "Controls which scenario types should execute this fixture.",
          "$ref": "#/$defs/FixtureExecuteFor"
        },
        "http-request": {
          "description": "HTTP request to send when executing the fixture.",
          "$ref": "#/$defs/HTTPFixtureRequest"
        },
        "http-response": {
          "description": "Expected HTTP response returned by the fixture call.",
          "$ref": "#/$defs/HTTPFixtureResponse"
        }
      },
      "required": ["type", "http-request", "http-response"],
      "additionalProperties": true
    },
    "Retry": {
      "type": "object",
      "examples": [
        {
          "max-attempts": 2,
          "delay": "PT1S"
        }
      ],
      "properties": {
        "max-attempts": {
          "description": "Maximum number of retry attempts for the fixture call.",
          "type": "integer"
        },
        "delay": {
          "description": "Delay between retry attempts.",
          "type": "string",
          "format": "duration"
        }
      },
      "additionalProperties": true
    },
    "FixtureExecuteFor": {
      "type": "object",
      "examples": [
        {
          "scenarios": "all"
        }
      ],
      "properties": {
        "scenarios": {
          "description": "Run this fixture for all, positive, or negative scenarios.",
          "default": "all",
          "type": "string",
          "enum": ["all", "positive", "negative"]
        }
      },
      "additionalProperties": true
    },
    "HTTPFixtureRequest": {
      "type": "object",
      "examples": [
        {
          "baseUrl": "http://localhost:9000",
          "method": "POST",
          "path": "/setup",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "state": "ready"
          }
        }
      ],
      "properties": {
        "baseUrl": {
          "description": "Base URL of the fixture endpoint.",
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "path": {
          "description": "Path to invoke on the fixture endpoint.",
          "type": "string"
        },
        "headers": {
          "type": "object"
        },
        "body": {
          "$ref": "#/$defs/AnyValue"
        }
      },
      "required": ["baseUrl", "method"],
      "additionalProperties": true
    },
    "HTTPFixtureResponse": {
      "type": "object",
      "examples": [
        {
          "status": 200,
          "body": {
            "ok": true
          }
        }
      ],
      "properties": {
        "status": {
          "description": "Expected HTTP status returned by the fixture call.",
          "type": "integer"
        },
        "body": {
          "$ref": "#/$defs/AnyValue"
        }
      },
      "required": ["status"],
      "additionalProperties": true
    },
    "PartialRequestResponseSchema": {
      "allOf": [
        {
          "$ref": "#/$defs/Metadata"
        },
        {
          "$ref": "#/$defs/RequestResponseSchema"
        }
      ]
    },
    "RequestSchema": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "query": {
          "type": "object"
        },
        "headers": {
          "type": "object"
        },
        "body": {
          "$ref": "#/$defs/AnyValue"
        },
        "form-fields": {
          "type": "object"
        },
        "multipart-formdata": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiPartFormData"
          }
        },
        "bodyRegex": {
          "type": "string"
        }
      },
      "required": ["method", "path"]
    },
    "ResponseSchema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 0
        },
        "headers": {
          "type": "object"
        },
        "body": {
          "$ref": "#/$defs/AnyValue"
        },
        "externalisedResponseCommand": {
          "type": "string"
        }
      },
      "required": ["status"]
    },
    "MultiPartFormData": {
      "oneOf": [
        {
          "$ref": "#/$defs/MultiPartContent"
        },
        {
          "$ref": "#/$defs/MultiPartFile"
        }
      ]
    },
    "MultiPartContent": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        }
      },
      "required": ["name", "content"]
    },
    "MultiPartFile": {
      "type": "object",
      "properties": {
        "contentEncoding": {
          "type": "string"
        },
        "contentType": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["name", "filename"]
    }
  }
}
