                  "producer": {
                    "key1": "${CONSUME_ASYNC_PRODUCER_PROP_KEY1_V2:producer-value-a}",
                    "key2": [
                      "${CONSUME_ASYNC_PRODUCER_PROP_KEY2_V2:producer-value-b}"
                    ],
                    "key3": {
                      "subKey": "${CONSUME_ASYNC_PRODUCER_PROP_SUBKEY_V2:producer-value-c}"
