    "provider": "${PIPELINE_PROVIDER:azure}",
    "organization": "${PIPELINE_ORG:acme-org}",
    "project": "${PIPELINE_PROJECT:acme-proj}",
    "definitionId": "${PIPELINE_DEFINITION_ID:42}"
  },
  "environments": {
