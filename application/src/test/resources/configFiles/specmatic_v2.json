              {
                "host": "${PROVIDE_ASYNC_SERVER_HOST:localhost}",
                "protocol": "${PROVIDE_ASYNC_SERVER_PROTOCOL:mqtt}",
                "client": {
                  "consumer": {
                    "key1": "${PROVIDE_ASYNC_CONSUMER_PROP_KEY1:value1}",
                    "key2": [ "${PROVIDE_ASYNC_CONSUMER_PROP_KEY2:value2}" ],
                    "key3": { "subKey": "${PROVIDE_ASYNC_CONSUMER_PROP_SUBKEY:value3}" }
                  },
                  "producer": {
                    "key1": "${PROVIDE_ASYNC_PRODUCER_PROP_KEY1:value1}",
                    "key2": [ "${PROVIDE_ASYNC_PRODUCER_PROP_KEY2:value2}" ],
                    "key3": { "subKey": "${PROVIDE_ASYNC_PRODUCER_PROP_SUBKEY:value3}" }
                  }
                },
                "adminCredentials": {
                  "key1": "${PROVIDE_ASYNC_ADMIN_PROP_KEY1:value1}",
                  "key2": [ "${PROVIDE_ASYNC_ADMIN_PROP_KEY2:value2}" ],
                  "key3": { "subKey": "${PROVIDE_ASYNC_ADMIN_PROP_SUBKEY:value3}" }
                }
              }
            ],
            "schemaRegistryProps": {
              "kind": "${PROVIDE_SCHEMA_REGISTRY_KIND:confluent}",
              "url": "${PROVIDE_SCHEMA_REGISTRY_URL:http://localhost:8081}",
              "username": "${PROVIDE_SCHEMA_REGISTRY_USERNAME:user}",
              "password": "${PROVIDE_SCHEMA_REGISTRY_PASSWORD:password}"
            }
          }
        },
        {
          "specs": [
            "${PROVIDE_GRPC_SPEC_PATH:specs/git/provide-config-value-grpc.proto}"
          ],
          "specType": "${PROVIDE_GRPC_SPEC_TYPE:protobuf}",
          "config": {
            "host": "${PROVIDE_GRPC_HOST:localhost}",
            "port": "${PROVIDE_GRPC_PORT:50051}",
            "protocVersion": "${PROVIDE_GRPC_PROTOC_VERSION:25.1}",
            "requestTimeout": "${PROVIDE_GRPC_REQUEST_TIMEOUT:5000}",
            "importPaths": [
              "${PROVIDE_GRPC_IMPORT_PATH_PRIMARY:proto}",
              "${PROVIDE_GRPC_IMPORT_PATH_SECONDARY:proto2}"
            ]
          }
        },
        {
          "specs": [
            "${PROVIDE_GRAPHQL_SPEC_PATH:specs/git/provide-config-value-graphql.graphql}"
          ],
          "specType": "${PROVIDE_GRAPHQL_SPEC_TYPE:graphqlsdl}",
          "config": {
            "host": "${PROVIDE_GRPC_HOST__2:localhost}",
            "port": "${PROVIDE_GRPC_PORT__2:50051}"
          }
        },
        {
          "specs": [
            "${PROVIDE_SPEC_6:specs/git/provide-config-value-openapi-v2.yaml}"
          ],
          "specType": "${PROVIDE_SPEC_6_TYPE:OpenAPI}",
          "config": {
            "baseUrl": "${PROVIDE_CFG_BASE_URL_V2:https://openapi-provider-v2.example.com}",
            "examples": [
              "${PROVIDE_EX_2:examples/provider-b}"
            ],
            "resiliencyTests": {
              "enable": "${PROVIDE_CFG_RESILIENCY_V2:all}"
            }
          }
        },
        {
          "specs": [
            "specs/git/provide-config-value-openapi-direct.yaml"
