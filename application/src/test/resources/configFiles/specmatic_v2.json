{
  "version": "2",
  "contracts": [
    {
      "git": {
        "url": "${POLY_GIT_URL:https://github.com/acme/contracts2.git}",
        "branch": "${POLY_GIT_BRANCH:develop}",
        "matchBranch": "${POLY_GIT_MATCH:false}"
      },
      "provides": [
        "${PROVIDE_SPEC_1:specs/git/provide-string.yaml}",
        {
          "specs": [
            "${PROVIDE_SPEC_2:specs/git/provide-full-url.yaml}"
          ],
          "baseUrl": "${PROVIDE_BASE_URL:https://provider.example.com}",
          "resiliencyTests": {
            "enable": "${PROVIDE_RESILIENCY_1:all}"
          }
        },
        {
          "host": "${PROVIDE_HOST:provider-host}",
          "port": "${PROVIDE_PORT:9001}",
          "specs": [
            "${PROVIDE_SPEC_3:specs/git/provide-partial-url.yaml}"
          ],
          "resiliencyTests": {
            "enable": "${PROVIDE_RESILIENCY_2:positiveOnly}"
          }
        },
        {
          "specs": [
            "${PROVIDE_SPEC_4:specs/git/provide-config-value.yaml}"
          ],
          "specType": "${PROVIDE_SPEC_4_TYPE:OpenAPI}",
          "config": {
            "baseUrl": "${PROVIDE_CFG_BASE_URL:https://openapi-test.example.com}",
            "examples": [
              "${PROVIDE_EX_1:examples/a}"
            ],
            "resiliencyTests": {
              "enable": "${PROVIDE_CFG_RESILIENCY:none}"
            }
          }
        },
        {
          "specs": [
            "${PROVIDE_SPEC_5:specs/git/provide-config-value-asyncapi.yaml}"
          ],
          "specType": "${PROVIDE_ASYNCAPI_SPEC_TYPE:AsyncAPI}",
