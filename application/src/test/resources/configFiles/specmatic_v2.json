          "specType": "${CONSUME_SPEC_TYPE_V2:OpenAPI}",
          "config": {
            "baseUrl": "${CONSUME_CFG_BASE_URL_V2:https://openapi-consumer-v2.example.com}",
            "examples": [
              "${CONSUME_EX_2:examples/mock-b}"
            ]
          }
        },
        {
          "specs": [
            "specs/git/consume-config-value-openapi-direct.yaml"
          ],
          "specType": "OpenAPI",
          "config": {
            "baseUrl": "https://openapi-mock.example.com",
            "examples": [
              "examples/mock-b"
            ]
          }
        },
        {
          "specs": [
            "${CONSUME_SPEC_7:specs/git/consume-config-value-asyncapi-v2.yaml}"
          ],
          "specType": "${CONSUME_ASYNCAPI_SPEC_TYPE_V2:AsyncAPI}",
