                "protocol": "${CONSUME_ASYNC_SERVER_PROTOCOL_V2:kafka}",
                "client": {
                  "consumer": {
                    "key1": "${CONSUME_ASYNC_CONSUMER_PROP_KEY1_V2:consumer-value-a}",
                    "key2": [
                      "${CONSUME_ASYNC_CONSUMER_PROP_KEY2_V2:consumer-value-b}"
                    ],
                    "key3": {
                      "subKey": "${CONSUME_ASYNC_CONSUMER_PROP_SUBKEY_V2:consumer-value-c}"
