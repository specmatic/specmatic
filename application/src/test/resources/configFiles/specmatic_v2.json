                "host": "${PROVIDE_ASYNC_SERVER_HOST_V2:provider-async-host}",
                "protocol": "${PROVIDE_ASYNC_SERVER_PROTOCOL_V2:kafka}",
                "client": {
                  "consumer": {
                    "key1": "${PROVIDE_ASYNC_CONSUMER_PROP_KEY1_V2:consumer-value-a}",
                    "key2": [
                      "${PROVIDE_ASYNC_CONSUMER_PROP_KEY2_V2:consumer-value-b}"
                    ],
                    "key3": {
                      "subKey": "${PROVIDE_ASYNC_CONSUMER_PROP_SUBKEY_V2:consumer-value-c}"
                    }
                  },
                  "producer": {
                    "key1": "${PROVIDE_ASYNC_PRODUCER_PROP_KEY1_V2:producer-value-a}",
                    "key2": [
                      "${PROVIDE_ASYNC_PRODUCER_PROP_KEY2_V2:producer-value-b}"
                    ],
                    "key3": {
                      "subKey": "${PROVIDE_ASYNC_PRODUCER_PROP_SUBKEY_V2:producer-value-c}"
