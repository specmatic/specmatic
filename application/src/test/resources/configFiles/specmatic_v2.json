                  "key1": "${PROVIDE_ASYNC_ADMIN_PROP_KEY1_V2:admin-value-a}",
                  "key2": [
                    "${PROVIDE_ASYNC_ADMIN_PROP_KEY2_V2:admin-value-b}"
                  ],
                  "key3": {
                    "subKey": "${PROVIDE_ASYNC_ADMIN_PROP_SUBKEY_V2:admin-value-c}"
                  }
                }
              }
            ],
            "schemaRegistryProps": {
              "kind": "${PROVIDE_SCHEMA_REGISTRY_KIND_V2:apicurio}",
              "url": "${PROVIDE_SCHEMA_REGISTRY_URL_V2:http://localhost:8082}",
              "username": "${PROVIDE_SCHEMA_REGISTRY_USERNAME_V2:provider-user-v2}",
              "password": "${PROVIDE_SCHEMA_REGISTRY_PASSWORD_V2:provider-password-v2}"
            }
          }
        },
        {
          "specs": [
            "specs/git/provide-config-value-asyncapi-direct.yaml"
          ],
          "specType": "AsyncAPI",
          "config": {
            "replyTimeout": 5000,
            "subscriberReadinessWaitTime": 3000,
            "servers": [
