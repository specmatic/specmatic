        "file": "${PROXY_KEYSTORE_FILE:certs/proxy.p12}",
        "password": "${PROXY_KEY_PASS:kp3}",
        "alias": "${PROXY_KEY_ALIAS:alias3}"
      },
      "keyStorePassword": "${PROXY_KEYSTORE_PASS:ksp3}",
      "mtlsEnabled": "${PROXY_MTLS:true}"
