          "config": {
            "host": "${PROVIDE_GRPC_HOST__4:localhost}",
            "port": "${PROVIDE_GRPC_PORT__4:50051}"
          }
        },
        {
          "specs": [
            "${CONSUME_SPEC_6:specs/git/consume-config-value-openapi-v2.yaml}"
