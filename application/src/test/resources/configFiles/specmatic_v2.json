        "OpenAPI": {
          "successCriteria": {
            "minThresholdPercentage": "${REPORT_MIN_THRESHOLD:80}",
            "maxMissedEndpointsInSpec": "${REPORT_MAX_MISSED:3}",
            "enforce": "${REPORT_ENFORCE:true}"
          }
        }
      }
    }
